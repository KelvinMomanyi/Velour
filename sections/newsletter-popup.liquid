<div id="newsletter-popup" class="newsletter-popup">
    <div class="newsletter-popup__overlay"></div>
    <div class="newsletter-popup-content color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}">
      <button class="close-popup" aria-label="Close newsletter popup">
        {% render 'icon-scentra', icon: 'close', size: 'large' %}
      </button>
      <div class="newsletter-card1">
        <div class="newcard-content">
          <h2>{{ section.settings.heading | default: 'Stay Updated!' }}</h2>
          <p>{{ section.settings.description | default: 'Subscribe to our newsletter and get the latest updates right in your inbox.' }}</p>
          {% form 'customer' %}
          <form action="{{ shop.url }}/contact#contact_form" method="post" accept-charset="UTF-8" class="subscribe-form">
            <input type="hidden" name="form_type" value="customer">
            <input type="hidden" name="utf8" value="✓">
            <input type="email" name="contact[email]" placeholder="Enter your email" required>
            <button type="submit" class='btn btn-primary'>Subscribe</button>
          </form>
        {% endform %}
        </div>
        <div class="card-image">
          {% if section.settings.image1 != blank %}
            <img src="{{ section.settings.image1 | image_url: width: 800 }}" 
                 srcset="{{ section.settings.image1 | image_url: width: 400 }} 400w,
                         {{ section.settings.image1 | image_url: width: 800 }} 800w"
                 sizes="(max-width: 600px) 100vw, 400px"
                 alt="{{ section.settings.heading | default: 'Newsletter' }}" loading="lazy"
                 width="800" height="800"> 
           {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}   
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  

<style>
    .newsletter-popup {
        display: none; /* Hidden by default */
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    /* Transparent overlay backdrop */
    .newsletter-popup__overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 50 | divided_by: 100.0 }});
        backdrop-filter: blur({{ section.settings.overlay_blur | default: 4 }}px);
        -webkit-backdrop-filter: blur({{ section.settings.overlay_blur | default: 4 }}px);
    }
      
    .newsletter-popup-content {
        position: relative;
        z-index: 1;
        padding: 0;
        max-width: 680px;
        width: 92%;
        overflow: hidden;
        box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255, 255, 255, 0.05);
        animation: popup-enter 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
        transform: translateY(20px) scale(0.97);
    }

    @keyframes popup-enter {
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .close-popup {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 99;
        background: transparent;
        border: none;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: inherit;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .close-popup:hover {
        opacity: 0.7;
        transform: scale(1.1);
    }

    .close-popup:focus-visible {
        outline: 2px solid var(--color-focus, #007bff);
        outline-offset: 2px;
    }

    .newsletter-card1 {
      display: flex;
      width: 100%;
      overflow: hidden;
    }
    
    .card-image {
      flex: 1;
      position: relative;
      min-height: 280px;
    }
    
    .card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .newcard-content {
      flex: 1;
      padding: 40px 32px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    
    .newcard-content h2 {
      margin: 0 0 12px;
      font-size: 26px;
      line-height: 1.2;
    }
    
    .newcard-content p {
      margin: 0 0 24px;
      font-size: 15px;
      opacity: 0.75;
      line-height: 1.5;
    }
    
    .subscribe-form {
      display: flex;
      flex-direction: row;
      gap: 10px;
    }
    
    .subscribe-form input[type="email"] {
      flex: 1;
      padding: 12px 16px;
      font-size: 15px;
      border: 1px solid rgba(128, 128, 128, 0.3);
      outline: 2px solid transparent;
      transition: border-color 0.25s ease, outline-color 0.25s ease;
      background: transparent;
    }

    .subscribe-form input[type="email"]:focus {
      outline: 2px solid var(--color-focus, #007bff);
      outline-offset: 2px;
      border-color: var(--color-focus, #007bff);
    }
    
    .subscribe-form button {
      padding: 12px 24px;
      font-size: 15px;
      border: none;
      cursor: pointer;
      transition: opacity 0.25s ease, transform 0.15s ease;
      font-weight: 600;
      letter-spacing: 0.02em;
    }
    
    .subscribe-form button:hover {
      opacity: 0.85;
      transform: translateY(-1px);
    }

    @media screen and (max-width: 575px) {
      .newsletter-card1 {
        flex-direction: column;
      }
      .card-image {
        min-height: 180px;
        max-height: 200px;
      }
      .newcard-content {
        padding: 24px 20px;
      }
      .newcard-content h2 {
        font-size: 20px;
        margin: 0 0 8px;
      }
      .newcard-content p {
        margin: 0 0 16px;
        font-size: 14px;
      }
      .subscribe-form {
        flex-direction: column;
      }
      .subscribe-form input[type="email"] {
        padding: 10px 14px;
        font-size: 14px;
      }
      .subscribe-form button {
        font-size: 14px;
        width: 100%;
      }
  }  
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const popup = document.getElementById('newsletter-popup');
        const cookieName = 'newsletterPopupSeen';
        const delay = {{ section.settings.popup_delay | default: 5 }} * 1000;
      
        function showPopup() {
          if (popup) popup.style.display = 'flex';
        }
      
        function closePopup() {
          if (popup) {
            popup.style.display = 'none';
          }
          document.cookie = `${cookieName}=true; max-age=86400; path=/`;
        }
      
        if (!document.cookie.split('; ').find(row => row.startsWith(cookieName))) {
          setTimeout(showPopup, delay);
        }
      
        const closeBtn = popup ? popup.querySelector('.close-popup') : null;
        if (closeBtn) {
          closeBtn.addEventListener('click', closePopup);
        }

        /* Close on overlay click */
        const overlay = popup ? popup.querySelector('.newsletter-popup__overlay') : null;
        if (overlay) {
          overlay.addEventListener('click', closePopup);
        }

        /* Close on Escape key */
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && popup && popup.style.display === 'flex') {
            closePopup();
          }
        });
    });
</script> 

{% schema %}
{
  "name": "Newsletter popup",
  "settings": [
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color scheme",
        "default": "scheme-1"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Stay Updated!"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "Subscribe to our newsletter and get the latest updates right in your inbox."
      },
      {
        "type": "image_picker",
        "id": "image1",
        "label": "Image"
      },
      {
        "type": "range",
        "id": "popup_delay",
        "min": 1,
        "max": 30,
        "step": 1,
        "unit": "s",
        "label": "Popup delay",
        "default": 5
      },
      {
        "type": "range",
        "id": "overlay_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "Overlay opacity",
        "default": 50
      },
      {
        "type": "range",
        "id": "overlay_blur",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Overlay blur",
        "default": 4
      }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Newsletter popup",
      "category": "Marketing"
    }
  ]
}
{% endschema %}
